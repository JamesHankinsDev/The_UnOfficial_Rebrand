rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // articles/{articleId}/**
    // - Authenticated users (writers) can upload
    // - Public can read (images/audio served publicly)
    match /articles/{articleId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
